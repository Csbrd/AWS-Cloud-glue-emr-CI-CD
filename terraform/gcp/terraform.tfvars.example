# LifeSync360 GCP Terraform 변수 예시
# 이 파일을 복사해 terraform.tfvars 로 이름을 바꾼 후 실제 값을 입력하세요.
# terraform.tfvars 는 .gitignore 에 의해 커밋되지 않습니다.

# ── Common ────────────────────────────────────────────────────────────────────
project_id    = "<GCP_PROJECT_ID>"           # 예: project-xxxxxxxx-xxxx-xxxx-xxxx
region        = "asia-northeast3"
gcs_bucket    = "lifesync-data-lake"
aws_s3_bucket = "<AWS_S3_CURATED_BUCKET>"    # 예: lifesync-dev-06-s3-curatedbucket-xxxxxxxx

# ── 01 Networking ─────────────────────────────────────────────────────────────
subnet_primary_cidr = "192.168.20.0/24"       # GCP VPC 서브넷 CIDR

# AWS Transit Gateway VPN Outside IP (AWS 콘솔 > Site-to-Site VPN > 터널 세부 정보에서 확인)
aws_tgw_ip_1 = "<AWS_TGW_VPN_OUTSIDE_IP_1>"
aws_tgw_ip_2 = "<AWS_TGW_VPN_OUTSIDE_IP_2>"

aws_vpc_cidrs = [
  "10.0.0.0/16",  # LifeSync360 Service VPC
]

# ── 02 Security ───────────────────────────────────────────────────────────────
# Storage Transfer Service 전용 IAM 사용자 (AKIA... 형식의 장기 자격증명)
aws_sts_access_key_id     = "<AWS_IAM_USER_ACCESS_KEY_ID>"
aws_sts_secret_access_key = "<AWS_IAM_USER_SECRET_ACCESS_KEY>"

# AWS Private API Gateway 엔드포인트 (AWS API GW 생성 후 입력)
aws_api_gw_url = ""

# ── 11 VPN ────────────────────────────────────────────────────────────────────
gcp_bgp_asn = 65002
aws_bgp_asn = 64512

# AWS VPN Connection 다운로드한 설정 파일에서 확인 (Pre-Shared Key)
vpn_shared_secret_1 = "<VPN_TUNNEL_1_PRE_SHARED_KEY>"
vpn_shared_secret_2 = "<VPN_TUNNEL_2_PRE_SHARED_KEY>"

# ── 03 Storage ────────────────────────────────────────────────────────────────
gcs_location = "ASIA-NORTHEAST3"

# ── 05 BigQuery ───────────────────────────────────────────────────────────────
bq_location = "asia-northeast3"

# ── 07 Cloud Run ──────────────────────────────────────────────────────────────
# Artifact Registry에 이미지를 push한 후 태그를 입력하세요.
# 형식: {region}-docker.pkg.dev/{project_id}/lifesync/{service}:{tag}
predict_runner_image = "<REGION>-docker.pkg.dev/<GCP_PROJECT_ID>/lifesync/predict-runner:<TAG>"
sender_image         = "<REGION>-docker.pkg.dev/<GCP_PROJECT_ID>/lifesync/sender:<TAG>"

# Vertex AI 배포 완료 후 모델 리소스명 입력 (미입력 시 더미 예측 결과 사용)
vertex_model_resource_name = ""

# ── 10 Monitoring ─────────────────────────────────────────────────────────────
alert_email = "<YOUR_EMAIL>"
